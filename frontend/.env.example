# ==============================================================
# FinTrack Pro — Frontend Environment Variables
# ==============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in the values for your environment.
#   3. NEVER commit .env or .env.local to source control.
# ==============================================================

# API Gateway base URL
# Local development:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8888
# Production: set this in your hosting provider's env var dashboard (Vercel, etc.)

# Google OAuth Client ID (safe to expose — restrict origins in Google Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
