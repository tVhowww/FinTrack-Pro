# ==============================================================
# FinTrack Pro — Docker Infrastructure Secrets
# ==============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in EVERY value below with your real secrets.
#   3. NEVER commit the .env file to source control.
# ==============================================================

# --- PostgreSQL: Identity Service DB ---
IDENTITY_DB_USER=postgres
IDENTITY_DB_PASSWORD=change_me_identity

# --- PostgreSQL: Wallet Service DB ---
WALLET_DB_USER=postgres
WALLET_DB_PASSWORD=change_me_wallet

# --- PostgreSQL: Transaction Service DB ---
TRANSACTION_DB_USER=postgres
TRANSACTION_DB_PASSWORD=change_me_transaction

# --- pgAdmin (Database Management UI) ---
PGADMIN_EMAIL=admin@fintrack.com
PGADMIN_PASSWORD=change_me_pgadmin
